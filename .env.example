# Pulse News API - Environment Template
# 1. Copy 'MyFirstApp/Secrets.plist' to your local machine (standard setup)
# 2. Add your keys below (for CI/CD or alternative loaders)
# 3. Ensure '.env' and 'Secrets.plist' are ignored in your VCS

GNEWS_API_KEY=your_gnews_key_here
GEMINI_API_KEY=your_gemini_key_here
ADMIN_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=your_secure_password
AUTH_SALT=generate_a_random_string_here
